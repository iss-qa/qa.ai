{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                ".next/**",
                "dist/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true,
            "passThroughEnv": [
                "WATCHPACK_POLLING",
                "CHOKIDAR_USEPOLLING",
                "CHOKIDAR_INTERVAL",
                "NODE_OPTIONS"
            ]
        },
        "test": {
            "dependsOn": [
                "^test"
            ]
        }
    }
}