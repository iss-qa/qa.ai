# =====================================================
# QAMind — Variaveis de ambiente para producao
#
# COMO USAR:
#   - Em deploy: cole esses valores na aba "Environment" do servico no EasyPanel
#   - Em teste local de prod: copie este arquivo para .env.production (ja gitignored)
#
# NUNCA commite este arquivo com valores reais.
# =====================================================


# =====================================================
# 1. DOMINIOS (Traefik / EasyPanel routing)
# =====================================================
WEB_HOST=qamind.issqa.com.br
API_HOST=api.qamind.issqa.com.br


# =====================================================
# 2. SUPABASE
# Mesma URL e mesma anon_key sao usadas tanto pelo web (browser) quanto pela api (backend).
# Next.js exige prefixo NEXT_PUBLIC_ pra expor a var no bundle do browser.
# A service_role_key SO existe no backend (NUNCA prefixar com NEXT_PUBLIC_).
# =====================================================

# (web + api) — mesma URL do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_URL=https://xxx.supabase.co

# (web) — anon/publishable key, ok expor no browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# (api) — service_role key, SECRETA, bypassa RLS
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx


# =====================================================
# 3. URLs internas da plataforma (browser → backends)
# =====================================================

# Browser fala com a api Fastify pra Settings/Integracoes/Sync de planilhas
NEXT_PUBLIC_API_URL=https://api.qamind.issqa.com.br

# Daemon Python (recorder/runner mobile) NAO vai pra VPS.
# A var aponta para localhost porque resolve no browser do usuario, que conecta
# ao SEU PROPRIO daemon quando ele rodar local. Mantem assim.
NEXT_PUBLIC_DAEMON_URL=http://localhost:8001


# =====================================================
# 4. API (Fastify) — runtime
# =====================================================

# CORS - precisa bater EXATAMENTE com o host do web (sem barra no final)
CORS_ORIGIN=https://qamind.issqa.com.br

# URL publica desta API. Usada para montar a "ingest_url" mostrada ao QA ao
# conectar um repositorio Web (Playwright). O runner do GitHub Actions faz
# POST dos resultados para {QAMIND_INGEST_URL}/web-runs/{runId}/ingest.
# Atras do Traefik a API tambem deriva isso dos headers X-Forwarded-*, mas
# defina explicitamente para garantir.
QAMIND_INGEST_URL=https://api.qamind.issqa.com.br

# Alias legado aceito pela API; mantenha igual ao QAMIND_INGEST_URL se usar.
PUBLIC_API_URL=https://api.qamind.issqa.com.br

# Anthropic - para features de IA do daemon/runs (opcional em prod inicial)
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# Org default usado por integrations (org_integrations linkado a uma org)
# Foi seedada por 007_organizations.sql. Mantem 'foxbit' a nao ser que crie outra.
DEFAULT_ORG_SLUG=foxbit


# =====================================================
# 5. CRIPTOGRAFIA — !!! CRITICO !!!
# Chave AES-256-GCM que cifra credenciais externas (Google Sheets, Jira)
# em org_integrations.credentials_cipher.
#
# GERAR:        openssl rand -base64 32
# ANOTAR:       1Password / Bitwarden / cofre da empresa
# PERDER:       todas as creds cifradas viram lixo, usuarios reconfiguram
# TROCAR:       mesmo resultado de perder — re-encripta tudo, nao trivial
#
# Em prod NUNCA use a mesma chave do dev local
# (a nao ser que voce queira que dev e prod compartilhem as mesmas creds Google).
# =====================================================
INTEGRATIONS_ENCRYPTION_KEY=cole-aqui-saida-de-openssl-rand-base64-32
