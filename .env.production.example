# =====================================================
# QAMind — Variaveis de ambiente para deploy
# Copie esses valores na aba "Environment" do servico no Dokploy
# NUNCA commite este arquivo com valores reais
# =====================================================

# ---------- Dominios (Traefik routing) ----------
WEB_HOST=qamind.issqa.com.br
API_HOST=api.qamind.issqa.com.br

# ---------- Frontend (build-time, inline no bundle) ----------
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
NEXT_PUBLIC_API_URL=https://api.qamind.issqa.com.br
# Daemon roda LOCAL na maquina do usuario (USB/ADB).
# Mantem localhost - browser do user se conecta ao seu proprio daemon quando ele estiver rodando.
NEXT_PUBLIC_DAEMON_URL=http://localhost:8001

# ---------- API (runtime) ----------
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
ANTHROPIC_API_KEY=sk-ant-api03-xxx
CORS_ORIGIN=https://qamind.issqa.com.br

# Org default - se vc rodou supabase_migration_organizations.sql, ja existe org "foxbit"
DEFAULT_ORG_SLUG=foxbit

# !!! CRITICO !!!
# Chave AES-256-GCM para cifrar credenciais em org_integrations.
# Gere com: openssl rand -base64 32
# Se voce TROCAR esta chave depois, todas as credenciais cifradas viram lixo
# (usuarios precisarao reconfigurar Google Sheets/Jira em /dashboard/settings/integrations).
# ANOTE EM LOCAL SEGURO (1Password / Bitwarden / cofre).
INTEGRATIONS_ENCRYPTION_KEY=cole-aqui-a-chave-gerada
